# Application settings
PORT=3000
ENVIRONMENT=${ENVIRONMENT}
APP_VERSION=${APP_VERSION}
NODE_ENV=production

# Database settings
DB_HOST=${DB_HOST}
DB_PORT=3306
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=${DB_NAME}

# Redis cache settings
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Logging settings
LOG_LEVEL=info